projection;
strict ( 2 );
use draft;

define behavior for ZC_PR_HEADER alias PRHeader
{
  use create;
  use update;
  use delete;

  use action submitForApproval;
  use action approve;
  use action reject;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Items { create; with draft; }
}

define behavior for ZC_PR_ITEM alias PRItem
{
  use update;
  use delete;

  use association _Header { with draft; }
}